import sqlite3
import pandas as pd

def get_album_features(db_path: str, album_name: str) -> pd.DataFrame:
    """
    Fetches feature columns for all tracks in a given album.
    """
    feature_cols = [
        'danceability', 'energy', 'loudness', 'speechiness', 'acousticness',
        'instrumentalness', 'liveness', 'valence', 'tempo'
    ]
    query = f"""
        SELECT f.{', f.'.join(feature_cols)}
        FROM albums_data a
        JOIN features_data f ON a.track_id = f.id
        WHERE lower(a.album_name) = lower(?)
    """
    with sqlite3.connect(db_path) as conn:
        df = pd.read_sql_query(query, conn, params=[album_name])
    return df


def summarize_features(df: pd.DataFrame) -> pd.DataFrame:
    """
    Returns summary statistics for each feature column.
    """
    df = df.apply(pd.to_numeric, errors='coerce')
    summary = df.agg(["mean", "median", "std", "min", "max"]).T
    summary.index.name = "feature"
    return summary

if __name__ == "__main__":
    db_path = "spotify_database.db"
    album_name = "Yours Truly"  

    try:
        features_df = get_album_features(db_path, album_name)
        if features_df.empty:
            print(f"No features found for album '{album_name}'.")
        else:
            summary = summarize_features(features_df)
            print(f"\nFeature summary for album: {album_name}\n")
            print(summary)
            
    except Exception as e:
        print(f"Error: {e}")
