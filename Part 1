import pandas as pd
import matplotlib.pyplot as plt
import numpy as np
import seaborn as sns

# Load the data
df = pd.read_csv('artist_data.csv')


# Display columns and data types
def col_types():
    columns= df.columns.tolist()
    data_types = df.dtypes
    print("Data types:")
    print(data_types)
    print("\nColumns:")
    print(columns)
    
# Count unique artists by 'name'
def unique():
    names = df['name'].unique()
    count_unique_artists = len(names)
    print(f"Unique artists:\n{count_unique_artists}")


# Top 10 by popularity
def top_10_popularity():
    df_sorted = df.sort_values(by=['artist_popularity'], ascending=False).head(10)
    return df_sorted[['name', 'artist_popularity']]


# Top 10 by followers
def top_10_followers():
    df_sorted = df.sort_values(by=['followers'], ascending=False).head(10)
    return df_sorted[['name', 'followers']]


# Plotting
def plot_top10():
    top_popularity = top_10_popularity()
    top_followers = top_10_followers()

    fig, axs = plt.subplots(1, 2, figsize=(18, 7))

    # Popularity plot
    axs[0].barh(top_popularity['name'], top_popularity['artist_popularity'])
    axs[0].set_title('Top 10 Artists by Popularity')
    axs[0].set_xlabel('Popularity')

    # Followers plot
    axs[1].barh(top_followers['name'], top_followers['followers'], color='salmon')
    axs[1].set_title('Top 10 Artists by Followers')
    axs[1].set_xlabel('Followers')
    axs[0].invert_yaxis()
    axs[1].invert_yaxis()

    plt.tight_layout()
    plt.show()

# --- Popularity vs Followers Analysis ---
# print("\n--- Popularity vs Followers Analysis ---")
def popularity_vs_followers():
    cdf = df[df['followers'] > 0].copy()
    correlation = cdf['artist_popularity'].corr(np.log(cdf['followers']))
    print(f"Correlation between popularity and followers: {correlation:.3f}")

import statsmodels.api as sm
def regression_model():
    cdf = df[df['followers'] > 0].copy()
    X = np.log(cdf['followers'])
    y = cdf['artist_popularity']
    X = sm.add_constant(X)  # voegt β0 toe
    
    model = sm.OLS(y, X).fit()
    # print(model.summary())
    
    return model

def plot_regression(model):
    cdf = df[df['followers'] > 0].copy()
    cdf['log_followers'] = np.log(cdf['followers'])

    plt.figure(figsize=(8,6))
    plt.scatter(cdf['log_followers'], cdf['artist_popularity'], alpha=0.3)

    X = sm.add_constant(cdf['log_followers'])
    predictions = model.predict(X)

    plt.plot(cdf['log_followers'], predictions, color='red')
    plt.xlabel('Followers')
    plt.ylabel('Popularity')
    plt.title('Popularity vs Followers')
    plt.show()



def over_legacy(model):
    cdf = df[df['followers'] > 0].copy()
    cdf['log_followers'] = np.log(cdf['followers'])

    X = sm.add_constant(cdf['log_followers'])
    cdf['predicted'] = model.predict(X)
    cdf['residual'] = cdf['artist_popularity'] - cdf['predicted']

    overperformers = cdf.sort_values(by='residual', ascending=False).head(10)
    legacy_artists = cdf.sort_values(by='residual').head(10)
    #Residual is the difference between an artist’s actual popularity and the popularity predicted by the model based on followers.
    
    print("\nTop Overperformers:")
    print(overperformers[['name', 'artist_popularity', 'followers', 'residual']])

    print("\nTop Legacy Artists:")
    print(legacy_artists[['name', 'artist_popularity', 'followers', 'residual']])



# # --- Genre Analysis Functions ---
def top10_by_genre(genre):
    #Pak alle genre kolommen
    genre_cols = [genre for genre in df.columns if genre.startswith("genre_")]

    selected_rows = []

    #Loop door elke rij
    for _, row in df.iterrows():

        #Maak een lijst van alle genres van deze artiest
        genres = [str(row[col]).lower() for col in genre_cols if pd.notna(row[col])]

        #Check of genre erin zit
        if genre in genres:
            selected_rows.append(row)

    filtered = pd.DataFrame(selected_rows)

    top10 = filtered.sort_values("artist_popularity", ascending=False).head(10)

    return top10[["name", "artist_popularity", "followers"]]



def analyze_genre_impact(df):
    """
    Analyseert of het aantal genres per artiest correleert met popularity en followers.
    Werkt met genre_1, genre_2, ... kolommen.
    """
    
    df = df.copy()
    
    # Pak alle genre kolommen
    genre_cols = [col for col in df.columns if col.startswith("genre_")]
    
    # Tel aantal niet-lege genres per rij
    df['genre_count'] = df[genre_cols].notna().sum(axis=1)
    
    # Correlaties
    corr_pop = df[['genre_count', 'artist_popularity']].corr().iloc[0,1]
    corr_follow = df[['genre_count', 'followers']].corr().iloc[0,1]
    
    print("Correlation genre count vs popularity:", round(corr_pop, 3))
    print("Correlation genre count vs followers:", round(corr_follow, 3))
    
    #plt Popularity
    plt.figure()
    sns.regplot(x='genre_count', y='artist_popularity', data=df)
    plt.title('Count genres vs Populariteit')
    plt.xlabel('Genre Count')
    plt.ylabel('Popularity')
    plt.show()
    
    #plt Followers
    plt.figure()
    sns.regplot(x='genre_count', y='followers', data=df)
    plt.title('count genres vs Followers')
    plt.xlabel('Genre Count')
    plt.ylabel('Followers')
    plt.show()
    
    return df

col_types()
unique()
print("Top 10 popularity:\n",top_10_popularity().to_string(index=False))
print("Top 10 followers:\n",top_10_followers().to_string(index=False))
plot_top10()
popularity_vs_followers()
print(regression_model().summary())
plot_regression(regression_model())
over_legacy(regression_model())
print(top10_by_genre('rap'))
analyze_genre_impact(df)
